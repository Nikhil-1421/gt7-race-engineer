# ---- copy to .env and fill in ----
# PlayStation IP (Settings > Network > View Connection Status). Omit for synthetic demo.
GT7_IP=192.168.1.42

# Discord bot token (Developer Portal > your app > Bot > Reset Token)
DISCORD_TOKEN=your-bot-token-here
# Optional: auto-join this voice channel on startup (right-click channel > Copy Channel ID)
DISCORD_VOICE_CHANNEL_ID=
# Optional: mirror callouts + reports to this text channel
DISCORD_TEXT_CHANNEL_ID=

# OpenAI key powers both the voice (TTS) and listening (STT)
OPENAI_API_KEY=sk-...
TTS_VOICE=onyx
ENGINEER_TWO_WAY=1
ENGINEER_WAKE_WORD=engineer

# Optional premium voice swap:
# TTS_PROVIDER=elevenlabs
# ELEVENLABS_API_KEY=...
# ELEVENLABS_VOICE_ID=...

# ---- Party-compatible output (engineer through a separate earpiece) ----
# Speak callouts from THIS machine (pair a Bluetooth earpiece to the Mac):
ENGINEER_LOCAL_VOICE=0          # set 1 to enable Mac speech
ENGINEER_TTS=auto              # auto | premium (cloud) | say (macOS built-in)
ENGINEER_SAY_VOICE=Daniel      # macOS 'say' voice when using built-in
